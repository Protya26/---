    <style>
        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 0;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(-45deg, #12c2e9, #c471ed, #f64f59, #23a6d5);
            background-size: 400% 400%;
            animation: gradientBG 12s ease infinite;
            overflow-x: hidden;
        }

        .container {
            width: 85%;
            max-width: 360px;
            padding: 40px 25px;
            background: rgba(255, 255, 255, 0.12);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 30px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
            text-align: center;
            animation: fadeIn 0.8s ease-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        h1 {
            color: white;
            font-size: 28px;
            margin-bottom: 10px;
            text-shadow: 2px 2px 8px rgba(0,0,0,0.2);
        }

        .subtitle {
            color: rgba(255, 255, 255, 0.8);
            font-size: 14px;
            margin-bottom: 30px;
            display: block;
        }

        .links-wrapper {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .social-link {
            display: flex;
            align-items: center;
            text-decoration: none;
            color: white;
            background: rgba(255, 255, 255, 0.08);
            padding: 16px 20px;
            border-radius: 18px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            -webkit-tap-highlight-color: transparent;
        }

        .social-link:active, .social-link:hover {
            background: rgba(255, 255, 255, 0.25);
            transform: scale(1.03);
            border-color: rgba(255, 255, 255, 0.4);
        }

        .social-link i {
            font-size: 24px;
            margin-right: 15px;
            color: #fff;
        }

        .social-link span {
            font-size: 16px;
            font-weight: 500;
            letter-spacing: 0.5px;
        }

        .footer {
            margin-top: 25px;
            font-size: 13px;
            color: rgba(255, 255, 255, 0.5);
            letter-spacing: 1px;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>Мои соц.сети</h1>
        <span class="subtitle">by @chudowishe0</span>
        
        <div class="links-wrapper">
            <a href="https://t.me/chudowishe0" class="social-link" target="_blank">
                <i class="fab fa-telegram-plane"></i>
                <span>Написать мне</span>
            </a>

            <a href="https://t.me/musics578" class="social-link" target="_blank">
                <i class="fas fa-music"></i>
                <span>Моя музыка</span>
            </a>

            <a href="https://t.me/textau7" class="social-link" target="_blank">
                <i class="fas fa-file-alt"></i>
                <span>Тексты песен</span>
            </a>
        </div>

        <div class="footer">© 2026 CHUDOWISHE0</div>
    </div>

</body>
</html>
